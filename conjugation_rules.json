      },
      "irr_kuru": {
        "type": "replace",
        "surface": "来ました",
        "reading": "きました"
      },
      "irr_aru": {
        "type": "replace",
        "surface": "ありました",
        "reading": "ありました"
      }
    }
  },
  "polite_negative": {
    "label": "Polite Negative (Masen / Desu)",
    "description": "Standard polite negative.",
    "introducedIn": "N5.5",
    "rules": {
      "godan": {
        "type": "godan_change",
        "map": "u_to_i",
        "add": "ません"
      },
      "ichidan": {
        "type": "suffix",
        "remove": "る",
        "add": "ません"
      },
      "irr_suru": {
        "type": "replace",
        "surface": "しません",
        "reading": "しません"
      },
      "irr_kuru": {
        "type": "replace",
        "surface": "来ません",
        "reading": "きません"
      },
      "i_adj": {
        "type": "suffix",
        "remove": "い",
        "add": "くないです"
      },
      "na_adj": {
        "type": "suffix",
        "add": "じゃありません"
      },
      "irr_ii": {
        "type": "replace",
        "surface": "よくないです",
        "reading": "よくないです"
      },
      "irr_aru": {
        "type": "replace",
        "surface": "ありません",
        "reading": "ありません"
      }
    }
  },
  "polite_past_negative": {
    "label": "Polite Past Negative",
    "description": "Standard polite past negative.",
    "introducedIn": "N5.5",
