  "tari_form": {
    "label": "Tari Form",
    "description": "Lists representative actions (～たり～たりする = 'doing things like X and Y'). Formed identically to plain past with たり/だり instead of た/だ. The godan euphonic changes are the same as ta_form.",
    "introducedIn": "N4.10",
    "rules": {
