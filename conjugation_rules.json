      },
      "irr_kuru": {
        "type": "replace",
        "surface": "来ませんでした",
        "reading": "きませんでした"
      },
      "i_adj": {
        "type": "suffix",
        "remove": "い",
        "add": "くなかったです"
      },
      "na_adj": {
        "type": "suffix",
        "add": "じゃありませんでした"
      },
