        "reading": "ありませんでした"
      }
    }
  },
  "polite_adj": {
    "label": "Polite Adjective (Desu)",
    "description": "Polite affirmative for adjectives.",
    "introducedIn": "N5.1",
    "rules": {
      "i_adj": {
        "type": "suffix",
        "add": "です"
      },
      "na_adj": {
        "type": "suffix",
