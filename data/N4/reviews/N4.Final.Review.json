    {
      "type": "grammar_roulette",
      "title": "🎡 Grammar Roulette",
      "emoji": "🎡",
      "instructions": "Spin the wheel and answer grammar questions from the category it lands on. Each spin is a surprise!",
      "count": 8,
      "categories": [
        {
          "label": "て-form",
          "color": "#E91E63",
          "items": [
            {
              "q": "Choose the correct て-form: 書く →",
              "choices": [
                "書いて",
                "書って",
                "書きて",
                "書して"
              ],
              "answer": "書いて",
              "explanation": "く-ending godan verbs use いて for て-form. 書く → 書いて."
            },
            {
              "q": "Fill in: 窓を＿＿ください。(Please open the window.)",
              "choices": [
                "開けて",
                "開いて",
                "開って",
                "開きて"
              ],
              "answer": "開けて",
              "explanation": "開ける (あける) is an ichidan verb → 開けて. 開けてください = Please open (it)."
            }
          ]
        },
        {
          "label": "は vs が",
          "color": "#9C27B0",
          "items": [
            {
              "q": "＿＿学生です。(I am a student.)",
              "choices": [
                "私は",
                "私が",
                "私を",
                "私に"
              ],
              "answer": "私は",
              "explanation": "は marks the topic — 'As for me, (I) am a student.' This is a general statement about yourself, so は is natural."
            },
            {
              "q": "だれ＿＿来ましたか。(Who came?)",
              "choices": [
                "が",
                "は",
                "を",
                "も"
              ],
              "answer": "が",
              "explanation": "が marks the subject when asking/answering 'who' or 'what' — the answer is new information. だれが来ましたか = Who came?"
            },
            {
              "q": "この本＿＿おもしろいです。(This book is interesting.)",
              "choices": [
                "は",
                "が",
                "を",
                "の"
              ],
              "answer": "は",
              "explanation": "は sets 'this book' as the topic being described. A general comment about a known item uses は."
            },
            {
              "q": "あ、犬＿＿います！(Oh, there's a dog!)",
              "choices": [
                "が",
                "は",
                "を",
