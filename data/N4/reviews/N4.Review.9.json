    {
      "type": "drills",
      "title": "Part 2: Grammar Scramble",
      "instructions": "Construct the sentence by clicking the words in the correct order.",
      "items": [
        {
          "kind": "scramble",
          "q": "I did things like walk along the sea and take photos.",
          "segments": [
            "海",
            "を",
            "歩いたり",
            "写真",
            "を",
            "とったり",
            "しました"
          ],
          "distractors": [
            "に",
            "歩きながら",
            "しません"
          ],
          "explanation": "The ～たり～たりする pattern lists representative actions: 歩いたり (walked, among other things) + とったり (took photos, etc.) + しました (past). Use を for both objects (海を, 写真を). The pattern shows a sampling of activities, not an exhaustive list."
        },
        {
          "kind": "scramble",
          "q": "I travelled while taking photos.",
          "segments": [
            "写真",
            "を",
            "とりながら",
            "旅行しました"
          ],
          "distractors": [
            "に",
            "とったり",
            "旅行します"
          ],
          "explanation": "The ～ながら pattern expresses simultaneous actions: 写真をとりながら (while taking photos) + 旅行しました (I travelled). ながら attaches to the masu-stem of the sub-action verb (とり). を marks 写真 as the object."
        },
        {
          "kind": "scramble",
          "q": "I have been to Hokkaido before.",
          "segments": [
            "北海道",
            "へ",
            "行ったことが",
            "あります"
          ],
          "distractors": [
            "に",
            "行きたいことが",
            "ありません"
          ],
          "explanation": "The ～たことがある pattern expresses past experience: 行った (plain past of 行く) + ことが + あります. The plain past form is required — not the polite past ました. へ marks Hokkaido as the destination."
        },
        {
          "kind": "scramble",
          "q": "Sunlight is brighter than moonlight.",
          "segments": [
            "月光",
            "より",
            "日光",
            "の",
            "ほうが",
            "明るいです"
          ],
          "distractors": [
            "を",
            "日光より",
            "明るくないです"
          ],
          "explanation": "The X より Y の ほうが ～ pattern: 月光より (than moonlight) + 日光のほうが (sunlight is more) + 明るいです (bright). より marks the standard of comparison; ほうが marks the winning side."
        },
        {
          "kind": "scramble",
          "q": "The wind is strong, so the trains are not running.",
          "segments": [
            "風",
            "が",
            "強くて",
            "電車",
            "が",
            "来ていません"
          ],
          "distractors": [
            "は",
            "強いですから",
            "来ません"
          ],
          "explanation": "強くて is the adverbial te-form of the い-adjective 強い, connecting the cause (strong wind) to the result. 来ていません is the negative progressive (trains are in a state of not running). が marks both 風 and 電車 as subjects. 来ません would mean 'won't come' (intentional), while 来ていません describes the current state."
        }
      ]
    },
