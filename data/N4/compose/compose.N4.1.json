  "conjugations": [
    {
      "pattern": "[noun] + です",
      "meaning": "is / am / are (polite)",
      "examples": ["帰り道は 電車です", "大切な 一日です"]
    },
    {
      "pattern": "[noun] + でした",
      "meaning": "was (polite past)",
      "examples": ["いい 一日でした", "長い 時間でした"]
    },
    {
      "pattern": "[noun] + ではありません",
      "meaning": "is not (polite formal)",
      "examples": ["借金では ありません", "大切な ことでは ありません"]
    },
    {
      "pattern": "[い-adj] + です",
      "meaning": "is [adj] (polite)",
      "examples": ["長いです", "大きいです", "新しいです"]
    },
    {
      "pattern": "[い-adj]〜い → 〜かったです",
      "meaning": "was [adj] (polite past)",
      "examples": ["長かったです", "大きかったです", "よかったです"]
    },
    {
      "pattern": "[い-adj]〜い → 〜く (adverbial)",
      "meaning": "[adj]-ly (adverb form)",
      "examples": ["大きく 切ります", "小さく 切ります"]
    },
    {
      "pattern": "[verb]〜ます",
      "meaning": "verb present / future (polite)",
      "examples": ["働きます", "帰ります", "使います"]
    },
    {
      "pattern": "[verb]〜ました",
      "meaning": "verb past (polite)",
      "examples": ["働きました", "帰りました", "着きました"]
    },
    {
      "pattern": "[verb]〜ません",
      "meaning": "verb negative (polite)",
      "examples": ["働きません", "帰りません", "使いません"]
    },
    {
      "pattern": "[verb]〜ています",
      "meaning": "is currently doing (progressive)",
      "examples": ["働いています", "使っています"]
    },
    {
      "pattern": "[verb]〜てください",
      "meaning": "please do [verb]",
      "examples": ["切ってください", "使ってください", "起きてください"]
    },
    {
      "pattern": "[verb]〜たいです",
      "meaning": "want to [verb]",
      "examples": ["作りたいです", "送りたいです", "帰りたいです"]
    },
    {
      "pattern": "[verb]〜ましょう",
      "meaning": "let's [verb]",
      "examples": ["一緒に 働きましょう", "帰りましょう"]
    },
    {
      "pattern": "[verb]〜ない",
      "meaning": "do not [verb] (plain negative)",
      "examples": ["働かない", "帰らない", "使わない"]
    }
  ]
