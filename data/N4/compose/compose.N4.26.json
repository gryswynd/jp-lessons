        "注意したら、問題が 分かりました"
      ]
    },
    {
      "pattern": "[verb-え] + ば",
      "meaning": "if [verb] (hypothetical conditional)",
      "examples": [
        "正しく 考えれば、いい 見方が 生まれます",
        "悪質な 考えに 注意すれば、正しく 進めます",
        "正しい 考え方で 始めれば、今年が よく 進みます"
      ]
    },
    {
      "pattern": "[plain form] + なら",
      "meaning": "if / given that [context] (contextual conditional)",
      "examples": [
        "正月が 来たなら、新しく 始めましょう",
        "考え方が 悪いなら、正して いきます",
        "正しく 考えるなら、正道を 歩きます"
      ]
    },
    {
      "pattern": "[plain form] + と",
      "meaning": "if / when [verb] → natural result",
      "examples": [
        "悪い 方で 進むと、問題が 大きく なります",
        "悪い 考えを 持って いると、見方も 悪く なります",
        "正しく 考えると、分かって きます"
      ]
    },
    {
      "pattern": "[verb-なければ] + いけない",
      "meaning": "must [verb] / have to [verb] (obligation)",
      "examples": [
