    },
    {
      "pattern": "い-adj + かったです",
      "meaning": "was [adjective] (polite past)",
      "examples": ["暑かったです", "寒かったです", "よかったです"]
    },
    {
      "pattern": "い-adj + くて",
      "meaning": "[adjective] and … (te-connector)",
      "examples": ["すずしくて", "暑くて", "白くて"]
    },
    {
      "pattern": "い-adj + くないです",
      "meaning": "is not [adjective] (polite negative)",
      "examples": ["寒くないです", "暑くないです"]
    },
    {
      "pattern": "verb-ます / verb-ました",
      "meaning": "do / did (polite)",
      "examples": ["行きます", "行きました", "あります", "なります"]
    },
    {
      "pattern": "verb-て + います",
      "meaning": "is doing / is in a state of (progressive)",
      "examples": ["住んでいます", "食べています"]
    },
    {
      "pattern": "verb-たいです",
      "meaning": "want to [verb] (polite desire)",
      "examples": ["行きたいです", "見たいです"]
    },
    {
      "pattern": "A は B より [adj]",
      "meaning": "A is more [adj] than B (comparison)",
      "examples": ["春は 夏より すずしいです", "秋の 山は 春の 山より きれいです"]
    },
    {
      "pattern": "A が いちばん [adj]",
      "meaning": "A is the most [adj] (superlative)",
