  "conjugations": [
    {
      "pattern": "[verb-て] + います",
      "meaning": "currently living / doing (progressive state)",
      "examples": ["住んで います", "さん歩 して います"]
    },
    {
      "pattern": "[noun / な-adj] + です",
      "meaning": "is / am / are (polite)",
      "examples": ["元気 です", "いい 所 です"]
    },
    {
      "pattern": "い-adj + です",
      "meaning": "is [adjective] (polite)",
      "examples": ["大きいです", "遠いです", "しずかです"]
    },
    {
      "pattern": "い-adj + かったです",
      "meaning": "was [adjective] (polite past)",
      "examples": ["暑かったです", "楽しかったです", "よかったです"]
    },
    {
      "pattern": "verb-ます / verb-ました",
      "meaning": "do / did (polite present / past)",
      "examples": ["行きます", "行きました", "別れました", "会いました"]
    },
    {
      "pattern": "verb-たいです",
      "meaning": "want to [verb] (polite desire)",
