  "conjugations": [
    {
      "pattern": "[verb-た] + ら",
      "meaning": "when / after [verb] (conditional — event sequence)",
      "examples": [
        "本を 読んだら、作文を 書きます",
        "研究が 終わったら、先生に 話します",
        "分かったら、教えて ください"
      ]
    },
    {
      "pattern": "[verb-て] + きました",
      "meaning": "has been gradually changing / came to [verb]",
      "examples": [
        "研究が 上手に なって きました",
        "少しずつ 分かって きました",
        "勉強して きました"
      ]
    },
    {
      "pattern": "[verb-て] + います",
      "meaning": "currently doing / ongoing state",
      "examples": [
        "文学を 研究して います",
        "文書を 読んで います",
        "注目して います"
      ]
    },
    {
      "pattern": "[verb-て] + いきます",
      "meaning": "will keep doing / ongoing action going forward",
      "examples": [
        "注意して 読んで いきます",
        "勉強して いきます",
        "毎日 勉強して いきます"
      ]
    },
    {
      "pattern": "[verb] + ために",
      "meaning": "in order to [verb] (purpose)",
      "examples": [
        "研究の ために 図書館に 行きます",
        "文学者に なる ために 勉強します"
      ]
    },
    {
      "pattern": "[verb-て] + もらいました",
      "meaning": "had someone do [verb] for you / received the action",
      "examples": [
        "作文を 見て もらいました",
        "先生に 教えて もらいました"
      ]
    },
    {
      "pattern": "[plain past verb] + そうです",
      "meaning": "I heard that … / apparently … (hearsay)",
      "examples": [
        "有名な 研究者が 書いた そうです",
        "図書館に 古い 文書が ある そうです"
      ]
    },
    {
      "pattern": "[verb/noun] + ことが できる",
      "meaning": "to be able to / it is possible to",
