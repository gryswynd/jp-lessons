    {
      "type": "grammarTable",
      "title": "All Forms of です / だ",
      "description": "The copula has polite (formal) and plain (informal) forms across four tenses and polarities. Use the same form throughout a conversation to maintain consistent register.",
      "tableType": "conjugation",
      "headers": [
        "Form",
        "Polite (です-style)",
        "Plain (だ-style)"
      ],
      "rows": [
        {
          "label": "Present",
          "cells": [
            "〜です",
            "〜だ"
          ],
          "meaning": "is / am / are"
        },
        {
          "label": "Past",
          "cells": [
            "〜でした",
            "〜だった"
          ],
          "meaning": "was / were"
        },
        {
          "label": "Negative",
          "cells": [
            "〜ではありません / 〜じゃありません",
            "〜ではない / 〜じゃない"
          ],
          "meaning": "is not / am not"
        },
        {
          "label": "Past Negative",
          "cells": [
            "〜ではありませんでした / 〜じゃありませんでした",
            "〜ではなかった / 〜じゃなかった"
          ],
          "meaning": "was not / were not"
        }
      ],
      "notes": [
        "じゃ is a casual contraction of では. Both are correct; じゃ sounds more natural in everyday spoken Japanese.",
        "In very casual speech, だ is often dropped after い-adjectives: うれしい！ (I'm happy!)"
      ]
    },
