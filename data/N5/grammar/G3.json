      "type": "fillSlot",
      "title": "Choose the Right Particle",
      "items": [
        {
          "before": "わたし",
          "slot": true,
          "after": "がくせいです。",
          "choices": [
            "は",
            "が",
            "の",
            "も"
          ],
          "answer": "は",
          "explanation": "は marks the topic — 'as for me, I am a student.'"
        },
        {
          "before": "だれ",
          "slot": true,
          "after": "先生ですか。",
          "choices": [
            "が",
            "は",
            "も",
            "の"
          ],
          "answer": "が",
          "explanation": "が follows question words like だれ (who) when they are the subject."
        },
        {
          "before": "先生",
          "slot": true,
          "after": "なまえは なんですか。",
          "choices": [
            "の",
            "は",
            "が",
            "も"
          ],
          "answer": "の",
          "explanation": "の connects two nouns: 先生の名前 = the teacher's name."
        },
        {
          "before": "あなたは がくせい",
          "slot": true,
          "after": "",
          "choices": [
            "か",
            "は",
            "も",
            "が"
          ],
          "answer": "か",
          "explanation": "か at the end of a statement turns it into a yes/no question."
        },
        {
