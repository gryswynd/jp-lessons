        "いっしょに 読みましょう"
      ]
    },
    {
      "pattern": "[な-adj] + に + なる",
      "meaning": "to become [adj] — state change with な-adjective",
      "examples": [
        "上手に なります",
        "上手に なりたいです",
        "上手に なっています"
      ]
    },
    {
      "pattern": "[い-adj stem] + かったです",
      "meaning": "polite past adjective — was large / was old (irregular: いい → よかったです)",
