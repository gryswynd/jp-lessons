        "買いました"
      ]
    },
    {
      "pattern": "[verb ます-stem] + ません",
      "meaning": "polite negative — does not go / exist",
      "examples": [
        "行きません",
        "ありません"
      ]
    },
    {
      "pattern": "[verb て-form] + ください",
      "meaning": "please do — polite request",
      "examples": [
