  "conjugations": [
    {
      "pattern": "[verb ます-stem] + ます / ました",
      "meaning": "polite present / polite past",
      "examples": ["行きます", "来ます", "食べました", "飲みました"]
    },
    {
      "pattern": "[verb ます-stem] + ません / ませんでした",
      "meaning": "polite negative / polite past negative",
      "examples": ["行きません", "食べませんでした", "来ません"]
    },
    {
      "pattern": "[verb て-form] + verb — sequential action",
      "meaning": "AてB = 'did A, then B'",
      "examples": ["食べて (ichidan: drop る → て)", "飲んで (godan む → んで)", "行って (行く exception!)"]
    },
    {
      "pattern": "[verb て-form] + います",
      "meaning": "ています = 'is doing' (ongoing) or 'is in that state'",
      "examples": ["食べています", "飲んでいます", "います (already here — resultant state)"]
    },
    {
      "pattern": "[verb て-form] + ください",
      "meaning": "てください = 'please do (verb)'",
      "examples": ["来てください", "食べてください", "行ってください"]
    },
    {
      "pattern": "[verb ます-stem] + たいです",
      "meaning": "たいです = 'want to do'",
      "examples": ["行きたいです", "食べたいです", "来たいです"]
    },
    {
      "pattern": "[verb ます-stem] + ましょう",
      "meaning": "ましょう = 'let's do / shall we'",
      "examples": ["行きましょう", "食べましょう", "来ましょう"]
    },
    {
      "pattern": "[plain form] + ない — plain negative",
      "meaning": "ない = 'don't do / is not' (casual speech and subordinate clauses)",
      "examples": ["行かない (く→か+ない)", "食べない (RU: drop る+ない)", "しない (する irregular)", "こない (くる irregular)", "ない (ある special irregular)"]
    },
    {
      "pattern": "[clause] + から + [result]",
      "meaning": "から = 'because' — reason clause comes FIRST",
      "examples": ["おいしいから、食べます", "行きたいですから、行きましょう", "前に ありますから、大丈夫です"]
    }
  ]
