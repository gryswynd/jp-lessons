  "conjugations": [
    {
      "pattern": "[godan verb] 買う → 買います",
      "meaning": "buy (polite forms of 買う)",
      "examples": ["買います", "買いました", "買いません", "買いませんでした"]
    },
    {
      "pattern": "[い-adjective] + です",
      "meaning": "is (adj) — polite affirmative",
      "examples": ["新しいです", "古いです", "高いです", "長いです"]
    },
    {
      "pattern": "[い-adjective] → remove い + くないです",
      "meaning": "is not (adj) — polite negative",
      "examples": ["高くないです", "長くないです", "古くないです"]
    },
    {
      "pattern": "[verb ます-stem] + たいです",
      "meaning": "want to (verb) — expresses desire",
      "examples": ["買いたいです", "食べたいです", "行きたいです"]
    },
    {
      "pattern": "[verb ます-stem] + たくないです",
      "meaning": "don't want to (verb) — negative desire",
      "examples": ["買いたくないです", "食べたくないです"]
    },
    {
      "pattern": "[verb ます-stem] + ましょう",
      "meaning": "let's (verb) — polite invitation or suggestion",
      "examples": ["買いましょう", "食べましょう", "行きましょう"]
    },
    {
      "pattern": "[て-form] + verb — sequential actions",
      "meaning": "AてB = 'did A, then B' — tense set by final verb",
