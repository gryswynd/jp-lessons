    {
      "type": "grammar_roulette",
      "title": "🎡 Grammar Roulette",
      "emoji": "🎡",
      "instructions": "Spin the wheel and answer grammar questions from the category it lands on!",
      "count": 10,
      "categories": [
        {
          "label": "です vs だ",
          "color": "#E91E63",
          "items": [
            {
              "q": "Which sentence uses the CORRECT polite form?",
              "choices": [
                "これは本です。",
                "これは本だ。",
                "これは本です、か。",
                "これは本のです。"
              ],
              "answer": "これは本です。",
              "explanation": "です is the polite copula — it attaches to nouns to make polite statements. だ is the plain/casual form used with friends. これは本です = 'This is a book (politely).'"
            },
            {
              "q": "Which is correct after an い-adjective?",
              "choices": [
                "この本はおもしろいです。",
                "この本はおもしろいだ。",
                "この本はおもしろです。",
                "この本はおもしろいだです。"
              ],
              "answer": "この本はおもしろいです。",
              "explanation": "い-adjectives DO take です in polite speech — おもしろいです is correct. What い-adjectives do NOT take is だ in plain speech (おもしろいだ is wrong). In plain speech, just say おもしろい."
            },
            {
              "q": "Fill in: 今日は日よう___。 (Casual: Today is Sunday.)",
              "choices": [
                "だ",
                "です",
                "でした",
                "ですか"
              ],
              "answer": "だ",
              "explanation": "だ is the plain/casual form of です. After nouns like 日ようび (Sunday), use だ in casual speech with friends or family."
            }
          ]
        },
        {
          "label": "は vs が",
          "color": "#9C27B0",
          "items": [
            {
              "q": "わたし＿＿学生です。 (I am a student — introducing yourself)",
              "choices": [
                "は",
                "が",
                "を",
                "の"
              ],
              "answer": "は",
              "explanation": "は marks the topic. When making a general statement about yourself, は sets 'I' as the topic being described. わたしは学生です = 'As for me, I am a student.'"
            },
            {
              "q": "あ、花＿＿あります！ (Oh, there are flowers!)",
              "choices": [
                "が",
                "は",
                "を",
                "に"
              ],
              "answer": "が",
              "explanation": "が introduces new, just-noticed information. When you suddenly spot something ('Oh! Flowers!'), use が to mark the subject of your spontaneous observation. 花があります = flowers exist (just noticed)."
            },
            {
              "q": "だれ＿＿来ましたか。 (Who came?)",
              "choices": [
                "が",
                "は",
                "を",
                "も"
              ],
              "answer": "が",
              "explanation": "が marks the subject when asking 'who' or 'what'. The answer is new information — だれが来ましたか? = Who came?"
            }
          ]
        },
        {
          "label": "に vs で",
          "color": "#FF9800",
          "items": [
            {
              "q": "学校＿＿本を読みます。 (I read books at school.)",
              "choices": [
                "で",
                "に",
                "は",
                "を"
              ],
              "answer": "で",
              "explanation": "で marks the location WHERE an action takes place. Reading is an active action happening AT school → で. If you used に, it would mean 'going TO school', not acting there."
            },
            {
              "q": "つくえの上＿＿本があります。 (There is a book on the desk.)",
              "choices": [
                "に",
                "で",
                "は",
                "を"
              ],
              "answer": "に",
              "explanation": "に marks the location WHERE something EXISTS. ある and いる (existence verbs) always use に for location. There is a book ON the desk → に."
            },
            {
              "q": "学校＿＿行きます。 (I go to school.)",
              "choices": [
                "に",
                "で",
                "を",
                "が"
              ],
              "answer": "に",
              "explanation": "に marks the DESTINATION of a movement verb. 行く, 来る (motion verbs) use に for where you are going. 学校に行きます = I go to school."
            }
          ]
        },
        {
          "label": "て-form",
          "color": "#4CAF50",
          "items": [
            {
              "q": "Choose the correct て-form of 飲む →",
              "choices": [
                "飲んで",
                "飲みて",
                "飲って",
                "飲いて"
              ],
              "answer": "飲んで",
              "explanation": "む-ending godan verbs use んで for て-form. 飲む → 飲んで. The same pattern applies to 読む → 読んで, and 飲む → 飲んで."
            },
            {
              "q": "Fill in: 本を読ん＿＿ください。 (Please read the book.)",
              "choices": [
                "で",
                "に",
                "を",
                "は"
              ],
              "answer": "で",
              "explanation": "Verb て-form + ください = polite request ('please do ~'). 読む (godan) → 読んで + ください = 読んでください = Please read it. The て-form of む-verbs ends in んで."
            }
          ]
        },
        {
          "label": "～たいです",
          "color": "#2196F3",
          "items": [
            {
              "q": "Which sentence correctly says 'I want to eat sushi'?",
              "choices": [
                "すしを食べたいです。",
                "すしを食べますたい。",
                "すしが食べていです。",
                "すしを食べたです。"
              ],
              "answer": "すしを食べたいです。",
              "explanation": "～たいです expresses desire: verb stem + たいです = 'want to ~'. 食べる → 食べ (stem) + たいです = 食べたいです. The object marker を is typically used."
            },
            {
              "q": "Fill in: 日本語を話し＿＿たいです。 (I want to speak Japanese.)",
              "choices": [
                "（nothing — 話したいです）",
                "て",
                "に",
                "が"
              ],
              "answer": "（nothing — 話したいです）",
              "explanation": "話す is a godan verb. The たい form uses the verb stem: 話す → 話し. So 話す → 話したいです. No extra particle is needed between the stem and たい."
            }
          ]
        }
      ]
    },
